# Local development env vars. Mirrors what the platform injects in production.

# Standard processor env vars (platform-provided on EFS in production)
INPUT_DIR=/data/input
OUTPUT_DIR=/data/output
EXECUTION_RUN_ID=local-r-001
ENVIRONMENT=local
REGION=us-east-1
DEPLOYMENT_MODE=basic

# Interactive-session env vars (injected by the ASL runTask.waitForTaskToken step
# in production). Leave TASK_TOKEN blank locally — the container then runs a plain
# JupyterLab with no Step Functions calls.
TASK_TOKEN=
SESSION_TYPE=r

# Local-only: bind to all interfaces and serve at the data dir so you can open
# http://localhost:8888 directly (in production the sidecar proxies to localhost).
JUPYTER_IP=0.0.0.0
JUPYTER_PORT=8888
NOTEBOOK_ROOT=/data
IDLE_TIMEOUT_SECONDS=3600
HEARTBEAT_INTERVAL_SECONDS=60
